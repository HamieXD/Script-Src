-- ระบบ Loop ยิง Remote Events (เมื่อกดยกเลิก UI ลูปนี้จะยังคงทำงานอยู่)
local rsEvents = game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents")

task.spawn(function()
    while task.wait() do
        if states.Train then pcall(function() rsEvents.TrainLevel:FireServer() end) end
        if states.Haki then pcall(function() rsEvents.TrainHaki:FireServer() end) end
        if states.Work then pcall(function() rsEvents.DoWork:FireServer(workList[currentWorkIndex]) end) end
        if states.Fish then pcall(function() rsEvents.FishCast:FireServer() end) end
    end
end)

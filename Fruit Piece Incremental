-- ระบบ Auto Farm
-- ==========================================
local states = {
    Train = false,
    Haki = false,
    Work = false,
    Fish = false
}

local workList = {
    "odd_jobs",
    "fishing",
    "bounty_hunt",
    "treasure_map",
    "raiding"
}
local currentWorkIndex = #workList 

-- ระบบทำงานของปุ่มปิด (X) -> เปิดทุกอย่างให้เป็น True และลบ UI ทิ้ง
closeBtn.MouseButton1Click:Connect(function()
    states.Train = true
    states.Haki = true
    states.Work = true
    states.Fish = true
    screenGui:Destroy() -- ลบหน้าต่างออก แต่ Loop ยังทำงานอยู่
end)

local function createToggleButton(name, yPos, stateKey)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 260, 0, 40)
    button.Position = UDim2.new(0, 20, 0, yPos)
    button.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    button.Text = name .. " : OFF"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 16
    button.Font = Enum.Font.GothamSemibold
    button.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = button

    button.MouseButton1Click:Connect(function()
        states[stateKey] = not states[stateKey]
        if states[stateKey] then
            button.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            button.Text = name .. " : ON"
        else
            button.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            button.Text = name .. " : OFF"
        end
    end)
end

createToggleButton("Auto Train Level", 50, "Train")
createToggleButton("Auto Train Haki", 100, "Haki")
createToggleButton("Auto Fish Cast", 260, "Fish")


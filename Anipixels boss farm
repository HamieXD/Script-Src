--// ===== Runner Logic =====
local running = false
local runnerThread = nil

local function setStatus(text)
	status.Text = "Status: " .. text
end

local function isRunning()
	return running
end

local function runLoop()
    setStatus("Running...")
    
    -- เพิ่ม while loop ตรงนี้เพื่อให้มันทำงานไปเรื่อยๆ จนกว่าเราจะกด STOP
    while running do 
        for _, name in ipairs(bosses) do
            if not running then break end

            setStatus("Searching: " .. name)
            local boss = campaign:FindFirstChild(name, true)
            if not boss then
                warn("Boss not found:", name)
                continue
            end

            local bossHRP = boss:FindFirstChild("HumanoidRootPart", true)
            if not (bossHRP and bossHRP:IsA("BasePart")) then
                warn("Found boss but no HumanoidRootPart:", name)
                continue
            end

            -- วาร์ป
            setStatus("Warping: " .. name)
            local char = getChar()
            if not running then break end
            char:PivotTo(bossHRP.CFrame * CFrame.new(0, 3, 6))

            -- ขอสูั
            if not running then break end
            setStatus("RequestBattle: " .. name)
            pcall(function()
                RequestBattle:FireServer(boss)
            end)

            -- รอเข้าฉากสู้
            if not safeWait(4.5, isRunning) then break end

            -- Give Up ซ้ำ
            setStatus("Win x3: " .. name)
            for i = 1, 3 do
                if not running then break end
                pcall(function()
                    BattleResult:FireServer("Won")
                end)
                if not safeWait(1, isRunning) then break end
            end
            if not running then break end

            -- เว้นให้โหลดออกจากฉาก
            setStatus("Exit battle wait: " .. name)
            if not safeWait(4, isRunning) then break end
        end
        
        -- ใส่ wait กันเกมค้าง เผื่อกรณีที่บอสไม่มีสักตัวแล้วลูปมันหมุนรัวๆ
        if running then
            task.wait(1) 
        end
    end

    -- จบ
    running = false
    toggleBtn.Text = "START"
    setStatus("Idle")
end

toggleBtn.MouseButton1Click:Connect(function()
	if running then
		-- STOP
		running = false
		toggleBtn.Text = "START"
		setStatus("Stopping...")
		return
	end

	-- START
	running = true
	toggleBtn.Text = "STOP"
	-- กันกดซ้อน
	if runnerThread and coroutine.status(runnerThread) ~= "dead" then
		-- ถ้ามีตัวเก่าค้าง (ปกติไม่ควร) ก็ปล่อยให้เช็ค running แล้วหยุดเอง
	end
	runnerThread = coroutine.create(runLoop)
	coroutine.resume(runnerThread)
end)

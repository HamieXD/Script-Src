--// ===== Helpers =====
local function getChar()
	local plr = Players.LocalPlayer
	return plr.Character or plr.CharacterAdded:Wait()
end

local function safeWait(seconds, runningFlagFn)
	-- wait แบบเช็ค stop ระหว่างทาง (หยุดไวขึ้น)
	local t = 0
	while t < seconds do
		if not runningFlagFn() then return false end
		local dt = math.min(0.15, seconds - t)
		task.wait(dt)
		t += dt
	end
	return true
end


--// ===== Logic: Auto Boss =====
local runningBoss = false
local bossThread = nil

local function isBossRunning() return runningBoss end

local function runBossLoop()
    statusBoss.Text = "Boss Status: Running..."
    
    while runningBoss do 
        for _, name in ipairs(bosses) do
            if not runningBoss then break end

            statusBoss.Text = "Searching: " .. name
            local boss = campaign:FindFirstChild(name, true)
            if not boss then continue end

            local bossHRP = boss:FindFirstChild("HumanoidRootPart", true)
            if not (bossHRP and bossHRP:IsA("BasePart")) then continue end

            statusBoss.Text = "Warping: " .. name
            local char = getChar()
            if not runningBoss then break end
            char:PivotTo(bossHRP.CFrame * CFrame.new(0, 3, 6))

            if not runningBoss then break end
            statusBoss.Text = "RequestBattle: " .. name
            pcall(function() RequestBattle:FireServer(boss) end)

            if not safeWait(4.5, isBossRunning) then break end

            statusBoss.Text = "Win x3: " .. name
            for i = 1, 3 do
                if not runningBoss then break end
                pcall(function() BattleResult:FireServer("Won") end)
                if not safeWait(1, isBossRunning) then break end
            end
            if not runningBoss then break end

            statusBoss.Text = "Exit battle wait: " .. name
            if not safeWait(4, isBossRunning) then break end
        end
        
        if runningBoss then task.wait(1) end
    end

    runningBoss = false
    toggleBossBtn.Text = "START AUTO BOSS"
    toggleBossBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    statusBoss.Text = "Boss Status: Idle"
end

toggleBossBtn.MouseButton1Click:Connect(function()
    if runningBoss then
        runningBoss = false
        toggleBossBtn.Text = "START AUTO BOSS"
        toggleBossBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        statusBoss.Text = "Boss Status: Stopping..."
    else
        runningBoss = true
        toggleBossBtn.Text = "STOP AUTO BOSS"
        toggleBossBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        bossThread = coroutine.create(runBossLoop)
        coroutine.resume(bossThread)
    end
end)

--// ===== Logic: Auto PVP Elo =====
local runningPvp = false
local pvpThread = nil

local function isPvpRunning() return runningPvp end

local function runPvpLoop()
    statusPvp.Text = "PVP Status: Running..."
    
    while runningPvp do
        statusPvp.Text = "PVP Status: Requesting Battle..."
        pcall(function()
            -- ค้นหาจุด EloLeaderboard เผื่อ Map โหลดช้าจะได้ไม่ error แดง
            local target = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("PVP") 
                           and workspace.Map.PVP:FindFirstChild("Deco") and workspace.Map.PVP.Deco:FindFirstChild("EloLeaderboard")
                           and workspace.Map.PVP.Deco.EloLeaderboard:FindFirstChild("First")
            if target then
                RequestBattle:FireServer(target)
            else
                statusPvp.Text = "PVP Status: Target Not Found!"
            end
        end)

        -- รอ 5 วิ ตามโค้ดต้นฉบับ
        if not safeWait(5, isPvpRunning) then break end

        statusPvp.Text = "PVP Status: Won"
        pcall(function()
            BattleResult:FireServer("Won")
        end)

        -- รอ cooldown ก่อนวนลูปใหม่ (ตั้งไว้ 2 วิ สามารถแก้ได้ถ้าต้องการให้เร็ว/ช้าลง)
        if not safeWait(2, isPvpRunning) then break end
    end

    runningPvp = false
    togglePvpBtn.Text = "START AUTO PVP ELO"
    togglePvpBtn.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
    statusPvp.Text = "PVP Status: Idle"
end

togglePvpBtn.MouseButton1Click:Connect(function()
    if runningPvp then
        runningPvp = false
        togglePvpBtn.Text = "START AUTO PVP ELO"
        togglePvpBtn.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        statusPvp.Text = "PVP Status: Stopping..."
    else
        runningPvp = true
        togglePvpBtn.Text = "STOP AUTO PVP ELO"
        togglePvpBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        pvpThread = coroutine.create(runPvpLoop)
        coroutine.resume(pvpThread)
    end
end)
